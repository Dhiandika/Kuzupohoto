---
const currentYear = new Date().getFullYear();
---

<footer
    class="w-full bg-neo-black border-t-[6px] border-neo-yellow mt-12 p-6 md:p-8 relative overflow-hidden"
>
    <!-- Background dotted accent -->
    <div
        class="absolute inset-0 opacity-20 pointer-events-none"
        style="background-image: radial-gradient(var(--color-neo-white) 2px, transparent 2px); background-size: 20px 20px;"
    >
    </div>

    <div
        class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-10 relative z-10"
    >
        <!-- Text -->
        <div class="text-center md:text-left">
            <h2
                class="font-black text-neo-white text-2xl md:text-4xl uppercase tracking-tighter mb-2"
            >
                Kuzupost<br />
                <span class="text-neo-pink">PhotoStrips.</span>
            </h2>
            <p class="font-bold text-neo-yellow text-base">
                &copy; {currentYear} Dibuat oleh Dhiandika Aditya.
            </p>
        </div>

        <!-- Social Icons -->
        <div class="flex gap-4">
            <a
                href="https://www.instagram.com/npemburu6/"
                target="_blank"
                rel="noopener noreferrer"
                class="w-12 h-12 md:w-14 md:h-14 border-[3px] border-neo-white flex items-center justify-center bg-neo-pink text-neo-black hover:-translate-y-1 hover:-translate-x-1 transition-transform shadow-[4px_4px_0_0_#ffffff]"
            >
                <i class="fa-brands fa-instagram text-2xl"></i>
            </a>
            <a
                href="https://www.facebook.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="w-12 h-12 md:w-14 md:h-14 border-[3px] border-neo-white flex items-center justify-center bg-neo-cyan text-neo-black hover:-translate-y-1 hover:-translate-x-1 transition-transform shadow-[4px_4px_0_0_#ffffff]"
            >
                <i class="fa-brands fa-facebook text-2xl"></i>
            </a>
            <a
                href="https://github.com/Dhiandika"
                target="_blank"
                rel="noopener noreferrer"
                class="w-12 h-12 md:w-14 md:h-14 border-[3px] border-neo-white flex items-center justify-center bg-neo-yellow text-neo-black hover:-translate-y-1 hover:-translate-x-1 transition-transform shadow-[4px_4px_0_0_#ffffff]"
            >
                <i class="fa-brands fa-github text-2xl"></i>
            </a>
            <a
                href="mailto:contact@example.com"
                class="w-12 h-12 md:w-14 md:h-14 border-[3px] border-neo-white flex items-center justify-center bg-neo-white text-neo-black hover:-translate-y-1 hover:-translate-x-1 transition-transform shadow-[4px_4px_0_0_#ffffff]"
            >
                <i class="fa-solid fa-envelope text-2xl"></i>
            </a>
        </div>

        <!-- Links -->
        <div
            class="flex flex-col md:flex-row gap-4 md:gap-8 font-black text-lg uppercase tracking-wider text-neo-white text-center"
        >
            <a
                href="/privacy"
                class="hover:text-neo-pink hover:-translate-y-1 transition-transform"
                >Privacy</a
            >
            <a
                href="/terms"
                class="hover:text-neo-cyan hover:-translate-y-1 transition-transform"
                >Terms</a
            >
            <a
                href="/support"
                class="hover:text-neo-yellow hover:-translate-y-1 transition-transform"
                >Support</a
            >
        </div>
    </div>
</footer>
