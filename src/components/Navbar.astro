---
const links = [
    { href: "/", label: "Beranda", icon: "fa-home" },
    { href: "/about", label: "About", icon: "fa-circle-info" },
    { href: "/contact", label: "Contact", icon: "fa-envelope" },
];

const currentPath = Astro.url.pathname;
---

<nav
    class="w-full bg-neo-white border-b-4 border-neo-black neo-shadow-lg sticky top-0 z-50 flex flex-col"
>
    <!-- Marquee Tape -->
    <div
        class="marquee-container w-full h-8 bg-neo-pink border-b-[3px] border-neo-black flex items-center overflow-hidden"
    >
        <div
            class="marquee-content text-neo-black text-xs md:text-sm font-bold tracking-widest uppercase"
        >
            <span
                >⭐ CAPTURE THE STORY ⭐ CREATE THE MEMORY ⭐ CAPTURE THE STORY
                ⭐ CREATE THE MEMORY ⭐ CAPTURE THE STORY ⭐ CREATE THE MEMORY
                ⭐</span
            >
            <span
                >⭐ CAPTURE THE STORY ⭐ CREATE THE MEMORY ⭐ CAPTURE THE STORY
                ⭐ CREATE THE MEMORY ⭐ CAPTURE THE STORY ⭐ CREATE THE MEMORY
                ⭐</span
            >
        </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <div class="flex justify-between h-16 items-center">
            <!-- Logo -->
            <div class="flex-shrink-0 flex items-center">
                <a
                    href="/"
                    class="flex flex-row items-center gap-2 hover:-translate-y-1 transition-transform"
                >
                    <img
                        src="/Logo-nav.png"
                        alt="PhotoStrips Logo"
                        class="h-10 w-auto object-contain drop-shadow-[2px_2px_0_rgba(0,0,0,1)]"
                    />
                </a>
            </div>

            <!-- Desktop Menu -->
            <div class="hidden md:flex space-x-6">
                {
                    links.map((link) => (
                        <a
                            href={link.href}
                            class={`font-bold text-base px-4 py-2 border-[3px] border-transparent hover:border-neo-black hover:bg-neo-yellow hover:-translate-y-1 transition-all flex items-center gap-2 ${
                                currentPath === link.href ||
                                currentPath === link.href + "/"
                                    ? "bg-neo-cyan border-neo-black neo-shadow"
                                    : "text-neo-black"
                            }`}
                        >
                            <i class={`fa ${link.icon}`} />
                            {link.label}
                        </a>
                    ))
                }
            </div>

            <!-- Mobile Menu Button -->
            <div class="md:hidden flex items-center">
                <button
                    id="mobile-menu-btn"
                    class="p-2 border-[3px] border-neo-black bg-neo-yellow neo-shadow active:translate-y-1 active:shadow-none transition-all"
                >
                    <i class="fa fa-bars text-lg"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div
        id="mobile-menu"
        class="hidden md:hidden border-t-4 border-neo-black bg-neo-white"
    >
        <div class="px-4 py-4 space-y-2 flex flex-col">
            {
                links.map((link) => (
                    <a
                        href={link.href}
                        class={`font-black text-lg flex items-center gap-3 px-4 py-3 border-4 border-neo-black hover:-translate-y-1 transition-transform ${
                            currentPath === link.href ||
                            currentPath === link.href + "/"
                                ? "bg-neo-cyan neo-shadow"
                                : "bg-neo-yellow hover:bg-neo-pink hover:neo-shadow"
                        }`}
                    >
                        <i class={`fa ${link.icon} w-6 text-center`} />
                        {link.label}
                    </a>
                ))
            }
        </div>
    </div>
</nav>

<script>
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");

    if (btn && menu) {
        btn.addEventListener("click", () => {
            menu.classList.toggle("hidden");
        });
    }
</script>
